<%- include('_header', { title: 'Sign in', username: null, currentPath: '/login' }) %>
<style>
  body {
    background:
      radial-gradient(circle at 15% 20%, rgba(99, 102, 241, 0.18), transparent 45%),
      radial-gradient(circle at 85% 80%, rgba(244, 114, 182, 0.15), transparent 45%),
      linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #312e81 100%);
    min-height: 100vh;
  }
  .glass {
    background: rgba(255, 255, 255, 0.97);
    backdrop-filter: blur(20px);
    box-shadow:
      0 25px 50px -12px rgba(0, 0, 0, 0.5),
      0 0 0 1px rgba(255, 255, 255, 0.1);
  }
  .logo-mark {
    background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 50%, #ec4899 100%);
    box-shadow: 0 10px 25px -5px rgba(99, 102, 241, 0.5);
  }
  .input-modern {
    transition: all 0.2s ease;
    background: #f8fafc;
  }
  .input-modern:focus {
    background: white;
    border-color: #6366f1;
    box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.12);
  }
  .btn-gradient {
    background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
    box-shadow: 0 10px 20px -5px rgba(79, 70, 229, 0.5);
    transition: all 0.2s ease;
  }
  .btn-gradient:hover {
    transform: translateY(-1px);
    box-shadow: 0 15px 25px -5px rgba(79, 70, 229, 0.6);
  }
  .btn-gradient:active { transform: translateY(0); }
  .floating-shape {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    opacity: 0.4;
    pointer-events: none;
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .fade-up { animation: fadeUp 0.5s ease-out; }
</style>

<div class="relative min-h-[90vh] flex items-center justify-center px-4 py-12 overflow-hidden">
  <div class="floating-shape w-72 h-72 bg-indigo-500" style="top: 10%; left: 5%;"></div>
  <div class="floating-shape w-96 h-96 bg-pink-500" style="bottom: 5%; right: 5%;"></div>

  <div class="relative w-full max-w-md fade-up">
    <div class="flex flex-col items-center mb-8">
      <div class="logo-mark w-16 h-16 rounded-2xl flex items-center justify-center mb-4">
        <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
      </div>
      <h1 class="text-3xl font-bold text-white tracking-tight">Fratelanza Admin</h1>
      <p class="text-sm text-indigo-200 mt-2">Control panel for your SaaS customers</p>
    </div>

    <form action="/login" method="post" class="glass rounded-3xl p-8 sm:p-10">
      <% if (error) { %>
        <div class="bg-rose-50 border border-rose-200 text-rose-700 text-sm rounded-xl p-3.5 mb-5 flex items-start gap-2.5">
          <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span><%= error %></span>
        </div>
      <% } %>

      <div class="mb-5">
        <label class="block text-xs font-semibold text-slate-600 uppercase tracking-wider mb-2">Username</label>
        <div class="relative">
          <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
          <input name="username" autofocus required autocomplete="username"
                 class="input-modern w-full border-2 border-slate-200 rounded-xl pl-11 pr-4 py-3 text-slate-900 placeholder-slate-400 focus:outline-none"
                 placeholder="admin" />
        </div>
      </div>

      <div class="mb-7">
        <label class="block text-xs font-semibold text-slate-600 uppercase tracking-wider mb-2">Password</label>
        <div class="relative">
          <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
          <input type="password" name="password" required autocomplete="current-password"
                 class="input-modern w-full border-2 border-slate-200 rounded-xl pl-11 pr-4 py-3 text-slate-900 placeholder-slate-400 focus:outline-none"
                 placeholder="••••••••" />
        </div>
      </div>

      <button type="submit" class="btn-gradient w-full text-white font-semibold rounded-xl py-3.5 text-base flex items-center justify-center gap-2">
        Sign in
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </button>

      <div class="mt-6 pt-5 border-t border-slate-100 text-center">
        <p class="text-xs text-slate-500">
          Authorized personnel only. All login attempts are logged.
        </p>
      </div>
    </form>

    <p class="text-center text-xs text-indigo-200/70 mt-6">
      &copy; <%= new Date().getFullYear() %> Fratelanza. All rights reserved.
    </p>
  </div>
</div>

<%- include('_footer') %>
