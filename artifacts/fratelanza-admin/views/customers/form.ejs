<%- include('../_header', { title: mode === 'new' ? 'New customer' : 'Edit customer' }) %>
<div class="max-w-3xl">
  <a href="<%= mode === 'edit' ? '/customers/' + customer.id : '/customers' %>" class="text-sm text-slate-500 hover:text-slate-900">← Back</a>
  <h1 class="text-2xl font-bold mt-2 mb-6"><%= mode === 'new' ? 'Add a new customer' : 'Edit ' + customer.name %></h1>

  <% if (error) { %>
    <div class="bg-red-50 border border-red-200 text-red-700 text-sm rounded-lg p-3 mb-4"><%= error %></div>
  <% } %>

  <form method="post" action="<%= mode === 'new' ? '/customers/new' : '/customers/' + customer.id + '/edit' %>" class="space-y-5">

    <div class="bg-white border border-slate-200 rounded-xl p-6 space-y-5">
      <h2 class="font-semibold text-slate-800">Basic info</h2>
      <div>
        <label class="block text-sm font-medium mb-1">Customer name *</label>
        <input name="name" required value="<%= customer.name %>" class="w-full border border-slate-300 rounded-lg px-3 py-2" placeholder="Acme Trading Co." />
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium mb-1">Subdomain *</label>
          <% if (mode === 'new') { %>
            <input name="subdomain" required value="<%= customer.subdomain %>" class="w-full border border-slate-300 rounded-lg px-3 py-2" placeholder="acme" />
            <p class="text-xs text-slate-500 mt-1">Accessed at <code>acme.fratelanza.com</code>. Cannot be changed later.</p>
          <% } else { %>
            <input value="<%= customer.subdomain %>" disabled class="w-full bg-slate-100 border border-slate-300 rounded-lg px-3 py-2 text-slate-500" />
          <% } %>
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Database name</label>
          <% if (mode === 'new') { %>
            <input name="db_name" value="<%= customer.db_name %>" class="w-full border border-slate-300 rounded-lg px-3 py-2 font-mono text-sm" placeholder="fratelanza_acme (auto)" />
            <p class="text-xs text-slate-500 mt-1">Leave empty to auto-generate from subdomain.</p>
          <% } else { %>
            <input value="<%= customer.db_name %>" disabled class="w-full bg-slate-100 border border-slate-300 rounded-lg px-3 py-2 text-slate-500 font-mono text-sm" />
          <% } %>
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium mb-1">Notes (internal)</label>
        <textarea name="notes" rows="2" class="w-full border border-slate-300 rounded-lg px-3 py-2" placeholder="Any internal notes…"><%= customer.notes || '' %></textarea>
      </div>
    </div>

    <div class="bg-white border border-slate-200 rounded-xl p-6 space-y-4">
      <h2 class="font-semibold text-slate-800">Medical specialization</h2>
      <p class="text-xs text-slate-500 -mt-2">Seeds related diagnosis suggestions and medical feature prompts for the tenant.</p>
      <select name="medical_specialization" class="w-full border border-slate-300 rounded-lg px-3 py-2">
        <% medicalSpecializations.forEach(function(s) { %>
          <option value="<%= s.key %>" <%= (customer.medical_specialization || 'general') === s.key ? 'selected' : '' %>><%= s.label %> · <%= s.labelAr %></option>
        <% }) %>
      </select>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3 text-xs text-slate-600">
        <% medicalSpecializations.forEach(function(s) { %>
          <div class="rounded-lg border border-slate-200 p-3">
            <div class="font-medium text-slate-800"><%= s.label %></div>
            <div class="mt-1"><span class="text-slate-400">Diagnosis:</span> <%= s.diagnoses.slice(0, 3).join(', ') %></div>
            <div class="mt-1"><span class="text-slate-400">Features:</span> <%= s.features.join(', ') %></div>
          </div>
        <% }) %>
      </div>
    </div>

    <div class="bg-white border border-slate-200 rounded-xl p-6 space-y-5">
      <h2 class="font-semibold text-slate-800">Primary contact</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div>
          <label class="block text-sm font-medium mb-1">Name</label>
          <input name="contact_name" value="<%= customer.contact_name || '' %>" class="w-full border border-slate-300 rounded-lg px-3 py-2" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Email</label>
          <input type="email" name="contact_email" value="<%= customer.contact_email || '' %>" class="w-full border border-slate-300 rounded-lg px-3 py-2" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Phone</label>
          <input name="contact_phone" value="<%= customer.contact_phone || '' %>" class="w-full border border-slate-300 rounded-lg px-3 py-2" />
        </div>
      </div>
    </div>

    <div class="bg-white border border-slate-200 rounded-xl p-6 space-y-5">
      <h2 class="font-semibold text-slate-800">Billing & subscription</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium mb-1">Plan name</label>
          <input name="plan_name" value="<%= customer.plan_name || '' %>" class="w-full border border-slate-300 rounded-lg px-3 py-2" placeholder="Basic / Pro / Enterprise" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Payment status</label>
          <select name="payment_status" class="w-full border border-slate-300 rounded-lg px-3 py-2">
            <% paymentStatuses.forEach(function(s) { %>
              <option value="<%= s %>" <%= customer.payment_status === s ? 'selected' : '' %>><%= s %></option>
            <% }) %>
          </select>
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium mb-1">Amount (EGP)</label>
          <input type="number" step="0.01" min="0" name="billing_amount" value="<%= customer.billing_amount || 0 %>" class="w-full border border-slate-300 rounded-lg px-3 py-2" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Billing cycle</label>
          <select name="billing_cycle" class="w-full border border-slate-300 rounded-lg px-3 py-2">
            <% billingCycles.forEach(function(c) { %>
              <option value="<%= c %>" <%= customer.billing_cycle === c ? 'selected' : '' %>><%= c %></option>
            <% }) %>
          </select>
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div>
          <label class="block text-sm font-medium mb-1">Subscription start</label>
          <input type="date" name="subscription_start" value="<%= fmtDate(customer.subscription_start) !== '—' ? fmtDate(customer.subscription_start) : '' %>" class="w-full border border-slate-300 rounded-lg px-3 py-2" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Subscription end</label>
          <input type="date" name="subscription_end" value="<%= fmtDate(customer.subscription_end) !== '—' ? fmtDate(customer.subscription_end) : '' %>" class="w-full border border-slate-300 rounded-lg px-3 py-2" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Next billing date</label>
          <input type="date" name="next_billing_date" value="<%= fmtDate(customer.next_billing_date) !== '—' ? fmtDate(customer.next_billing_date) : '' %>" class="w-full border border-slate-300 rounded-lg px-3 py-2" />
        </div>
      </div>
    </div>

    <div class="bg-white border border-slate-200 rounded-xl p-6 space-y-5">
      <h2 class="font-semibold text-slate-800">Enabled features</h2>
      <p class="text-xs text-slate-500 -mt-3">Use the section toggle to enable or disable a whole section at once, or pick individual features.</p>

      <% featureGroups.forEach(function(group) {
           var groupChecked = group.keys.every(function(k){ return features[k]; });
           var groupPartial = !groupChecked && group.keys.some(function(k){ return features[k]; });
      %>
        <div class="border border-slate-200 rounded-lg overflow-hidden" data-feature-group="<%= group.id %>">
          <div class="flex items-center justify-between gap-3 px-4 py-3 bg-slate-50 border-b border-slate-200">
            <label class="flex items-center gap-3 cursor-pointer flex-1">
              <input
                type="checkbox"
                class="w-5 h-5 accent-slate-900"
                data-group-master="<%= group.id %>"
                <%= groupChecked ? 'checked' : '' %>
                <% if (groupPartial) { %> data-indeterminate="true"<% } %>
              />
              <span class="font-medium text-slate-800"><%= group.en %> <span class="text-slate-400 font-normal">· <%= group.ar %></span></span>
              <span class="ml-auto text-xs text-slate-500" data-group-count="<%= group.id %>"></span>
            </label>
            <div class="flex items-center gap-1.5">
              <button type="button" data-group-action="enable" data-group-target="<%= group.id %>" class="text-xs px-2 py-1 rounded border border-slate-300 bg-white hover:bg-slate-100">Enable all</button>
              <button type="button" data-group-action="disable" data-group-target="<%= group.id %>" class="text-xs px-2 py-1 rounded border border-slate-300 bg-white hover:bg-slate-100">Disable all</button>
            </div>
          </div>
          <div class="p-3 grid grid-cols-1 md:grid-cols-2 gap-2">
            <% group.keys.forEach(function(k) { %>
              <label class="flex items-center gap-3 px-3 py-2 rounded-lg border border-slate-200 hover:bg-slate-50 cursor-pointer">
                <input type="checkbox" name="feature_<%= k %>" <%= features[k] ? 'checked' : '' %> class="w-4 h-4" data-group-member="<%= group.id %>" />
                <span class="text-sm"><%= featureLabels[k].en %> <span class="text-slate-400">· <%= featureLabels[k].ar %></span></span>
              </label>
            <% }) %>
          </div>
        </div>
      <% }) %>
    </div>

    <script>
      (function () {
        function members(groupId) {
          return Array.prototype.slice.call(document.querySelectorAll('[data-group-member="' + groupId + '"]'));
        }
        function syncMaster(groupId) {
          var master = document.querySelector('[data-group-master="' + groupId + '"]');
          var mems = members(groupId);
          var on = mems.filter(function (m) { return m.checked; }).length;
          if (master) {
            master.checked = on === mems.length && mems.length > 0;
            master.indeterminate = on > 0 && on < mems.length;
          }
          var count = document.querySelector('[data-group-count="' + groupId + '"]');
          if (count) count.textContent = on + ' / ' + mems.length + ' enabled';
        }
        document.querySelectorAll('[data-feature-group]').forEach(function (el) {
          var groupId = el.getAttribute('data-feature-group');
          var master = el.querySelector('[data-group-master="' + groupId + '"]');
          if (master && master.getAttribute('data-indeterminate') === 'true') master.indeterminate = true;
          if (master) master.addEventListener('change', function () {
            members(groupId).forEach(function (m) { m.checked = master.checked; });
            syncMaster(groupId);
          });
          members(groupId).forEach(function (m) {
            m.addEventListener('change', function () { syncMaster(groupId); });
          });
          syncMaster(groupId);
        });
        document.querySelectorAll('[data-group-action]').forEach(function (btn) {
          btn.addEventListener('click', function () {
            var groupId = btn.getAttribute('data-group-target');
            var on = btn.getAttribute('data-group-action') === 'enable';
            members(groupId).forEach(function (m) { m.checked = on; });
            syncMaster(groupId);
          });
        });
      })();
    </script>

    <div class="pt-2 flex items-center gap-3">
      <button class="bg-slate-900 hover:bg-slate-800 text-white font-medium px-5 py-2 rounded-lg"><%= mode === 'new' ? 'Create customer' : 'Save changes' %></button>
      <a href="<%= mode === 'edit' ? '/customers/' + customer.id : '/customers' %>" class="text-sm text-slate-600 hover:text-slate-900">Cancel</a>
    </div>
  </form>
</div>
<%- include('../_footer') %>
