<%- include('../_header', { title: 'Customers' }) %>
<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold">Customers</h1>
  <a href="/customers/new" class="bg-slate-900 hover:bg-slate-800 text-white text-sm font-medium px-4 py-2 rounded-lg">+ Add customer</a>
</div>
<form method="get" class="mb-4">
  <input name="q" value="<%= q %>" placeholder="Search by name or subdomain…" class="w-full md:w-80 border border-slate-300 rounded-lg px-3 py-2 text-sm" />
</form>
<div class="bg-white border border-slate-200 rounded-xl overflow-hidden">
  <% if (customers.length === 0) { %>
    <div class="p-8 text-center text-slate-500 text-sm">No customers found.</div>
  <% } else { %>
    <table class="w-full text-sm">
      <thead class="bg-slate-50 text-slate-600 text-xs uppercase">
        <tr>
          <th class="text-left px-5 py-3">Name</th>
          <th class="text-left px-5 py-3">Subdomain</th>
          <th class="text-left px-5 py-3">Database</th>
          <th class="text-left px-5 py-3">Status</th>
          <th class="text-left px-5 py-3">Features</th>
          <th class="text-right px-5 py-3">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% customers.forEach(function(c) {
             const enabledCount = Object.values(c.features || {}).filter(Boolean).length;
             const totalCount = Object.keys(featureLabels).length;
        %>
          <tr>
            <td class="px-5 py-3 font-medium"><%= c.name %></td>
            <td class="px-5 py-3 text-slate-600"><%= c.subdomain %></td>
            <td class="px-5 py-3 font-mono text-xs text-slate-500"><%= c.db_name %></td>
            <td class="px-5 py-3">
              <span class="text-xs px-2 py-1 rounded-full <%= c.status === 'active' ? 'bg-emerald-100 text-emerald-700' : 'bg-red-100 text-red-700' %>"><%= c.status %></span>
            </td>
            <td class="px-5 py-3 text-xs text-slate-600"><%= enabledCount %> / <%= totalCount %> enabled</td>
            <td class="px-5 py-3 text-right space-x-1 whitespace-nowrap">
              <a href="/customers/<%= c.id %>/edit" class="inline-block text-xs px-2 py-1 rounded border border-slate-300 hover:bg-slate-100">Edit</a>
              <% if (c.status === 'active') { %>
                <form action="/customers/<%= c.id %>/block" method="post" class="inline" onsubmit="return confirm('Block this customer? Their CRM will show a paused page.');">
                  <button class="text-xs px-2 py-1 rounded bg-red-600 hover:bg-red-700 text-white">Block</button>
                </form>
              <% } else { %>
                <form action="/customers/<%= c.id %>/unblock" method="post" class="inline">
                  <button class="text-xs px-2 py-1 rounded bg-emerald-600 hover:bg-emerald-700 text-white">Unblock</button>
                </form>
              <% } %>
              <form action="/customers/<%= c.id %>/delete" method="post" class="inline" onsubmit="return confirm('PERMANENTLY delete this customer record? (Their database is NOT deleted.)');">
                <button class="text-xs px-2 py-1 rounded text-red-600 hover:bg-red-50 border border-red-200">Delete</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>
<%- include('../_footer') %>
