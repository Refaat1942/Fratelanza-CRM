<%- include('../_header', { title: 'Customers' }) %>
<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold">Customers</h1>
  <a href="/customers/new" class="bg-slate-900 hover:bg-slate-800 text-white text-sm font-medium px-4 py-2 rounded-lg">+ Add customer</a>
</div>
<form method="get" class="mb-4">
  <input name="q" value="<%= q %>" placeholder="Search by name or subdomain…" class="w-full md:w-80 border border-slate-300 rounded-lg px-3 py-2 text-sm" />
</form>
<div class="bg-white border border-slate-200 rounded-xl overflow-hidden">
  <% if (customers.length === 0) { %>
    <div class="p-8 text-center text-slate-500 text-sm">No customers found.</div>
  <% } else { %>
    <table class="w-full text-sm">
      <thead class="bg-slate-50 text-slate-600 text-xs uppercase">
        <tr>
          <th class="text-left px-4 py-3">Name</th>
          <th class="text-left px-4 py-3">Subdomain</th>
          <th class="text-left px-4 py-3">Plan</th>
          <th class="text-left px-4 py-3">Amount</th>
          <th class="text-left px-4 py-3">Next bill</th>
          <th class="text-left px-4 py-3">Pay</th>
          <th class="text-left px-4 py-3">Status</th>
          <th class="text-left px-4 py-3">DB</th>
          <th class="text-right px-4 py-3">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% customers.forEach(function(c) {
             const ps = c.provision_status || 'pending';
             const psClass = ps === 'ready' ? 'bg-emerald-100 text-emerald-700'
                           : ps === 'failed' ? 'bg-red-100 text-red-700'
                           : ps === 'provisioning' ? 'bg-amber-100 text-amber-700'
                           : 'bg-slate-100 text-slate-600';
             const payClass = c.payment_status === 'paid' ? 'bg-emerald-100 text-emerald-700'
                           : c.payment_status === 'overdue' ? 'bg-red-100 text-red-700'
                           : c.payment_status === 'due' ? 'bg-amber-100 text-amber-700'
                           : c.payment_status === 'cancelled' ? 'bg-slate-100 text-slate-600'
                           : 'bg-blue-100 text-blue-700';
        %>
          <tr class="hover:bg-slate-50">
            <td class="px-4 py-3 font-medium"><a href="/customers/<%= c.id %>" class="hover:underline"><%= c.name %></a></td>
            <td class="px-4 py-3 text-slate-600"><%= c.subdomain %></td>
            <td class="px-4 py-3 text-slate-700"><%= c.plan_name || '—' %></td>
            <td class="px-4 py-3 text-slate-700"><%= fmtMoney(c.billing_amount) %></td>
            <td class="px-4 py-3 text-slate-600"><%= fmtDate(c.next_billing_date) %></td>
            <td class="px-4 py-3"><span class="text-xs px-2 py-1 rounded-full <%= payClass %>"><%= c.payment_status || 'trial' %></span></td>
            <td class="px-4 py-3"><span class="text-xs px-2 py-1 rounded-full <%= c.status === 'active' ? 'bg-emerald-100 text-emerald-700' : 'bg-red-100 text-red-700' %>"><%= c.status %></span></td>
            <td class="px-4 py-3"><span class="text-xs px-2 py-1 rounded-full <%= psClass %>" <%= c.provision_error ? `title="${c.provision_error.replace(/"/g,'&quot;')}"` : '' %>><%= ps %></span></td>
            <td class="px-4 py-3 text-right space-x-1 whitespace-nowrap">
              <a href="/customers/<%= c.id %>" class="inline-block text-xs px-2 py-1 rounded bg-slate-900 hover:bg-slate-800 text-white">View</a>
              <a href="/customers/<%= c.id %>/edit" class="inline-block text-xs px-2 py-1 rounded border border-slate-300 hover:bg-slate-100">Edit</a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>
<%- include('../_footer') %>
