<%- include('_header', { title: 'Dashboard' }) %>
<h1 class="text-2xl font-bold mb-6">Dashboard</h1>

<% if (alerts && alerts.length > 0) { %>
  <div class="bg-amber-50 border border-amber-300 rounded-xl p-4 mb-6">
    <div class="flex items-start gap-3">
      <div class="text-amber-600 text-xl leading-none mt-1">⚠</div>
      <div class="flex-1">
        <div class="font-semibold text-amber-900">Payment alerts (<%= alerts.length %>)</div>
        <div class="mt-2 space-y-1">
          <% alerts.forEach(function(a) { %>
            <a href="/customers/<%= a.id %>" class="block px-3 py-2 rounded bg-white hover:bg-amber-100 border border-amber-200 text-sm flex justify-between items-center gap-3">
              <div>
                <span class="font-medium"><%= a.name %></span>
                <span class="text-slate-500 ml-2"><%= a.subdomain %></span>
              </div>
              <div class="flex items-center gap-3 text-xs">
                <% if (a.payment_status === 'overdue') { %>
                  <span class="px-2 py-0.5 rounded bg-red-100 text-red-700 font-medium">OVERDUE</span>
                <% } else if (a.days_until !== null && a.days_until <= 0) { %>
                  <span class="px-2 py-0.5 rounded bg-red-100 text-red-700 font-medium">due today</span>
                <% } else if (a.days_until !== null) { %>
                  <span class="px-2 py-0.5 rounded bg-amber-100 text-amber-800 font-medium">due in <%= a.days_until %>d</span>
                <% } %>
                <span class="text-slate-600"><%= fmtMoney(a.billing_amount) %> EGP</span>
              </div>
            </a>
          <% }) %>
        </div>
      </div>
    </div>
  </div>
<% } %>

<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
  <div class="bg-white border border-slate-200 rounded-xl p-5">
    <div class="text-sm text-slate-500">Total customers</div>
    <div class="text-3xl font-bold mt-2"><%= stats.total %></div>
  </div>
  <div class="bg-white border border-slate-200 rounded-xl p-5">
    <div class="text-sm text-slate-500">Active</div>
    <div class="text-3xl font-bold mt-2 text-emerald-600"><%= stats.active %></div>
  </div>
  <div class="bg-white border border-slate-200 rounded-xl p-5">
    <div class="text-sm text-slate-500 flex items-center gap-1">
      <span class="inline-block w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
      Online now
    </div>
    <div class="text-3xl font-bold mt-2 text-emerald-600"><%= stats.online %></div>
    <div class="text-xs text-slate-400 mt-1">active in last 5 min</div>
  </div>
  <div class="bg-white border border-slate-200 rounded-xl p-5">
    <div class="text-sm text-slate-500">Blocked</div>
    <div class="text-3xl font-bold mt-2 text-red-600"><%= stats.blocked %></div>
  </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
  <div class="bg-white border border-slate-200 rounded-xl p-5">
    <div class="text-sm text-slate-500">MRR (active subs)</div>
    <div class="text-2xl font-bold mt-2 text-slate-900"><%= fmtMoney(billing.mrr) %> <span class="text-sm font-normal text-slate-500">EGP / month</span></div>
  </div>
  <div class="bg-white border border-slate-200 rounded-xl p-5">
    <div class="text-sm text-slate-500">Due within 7 days</div>
    <div class="text-2xl font-bold mt-2 text-amber-600"><%= billing.due_soon %></div>
  </div>
  <div class="bg-white border border-slate-200 rounded-xl p-5">
    <div class="text-sm text-slate-500">Overdue</div>
    <div class="text-2xl font-bold mt-2 text-red-600"><%= billing.overdue %></div>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <div class="bg-white border border-slate-200 rounded-xl">
    <div class="px-5 py-3 border-b border-slate-200 flex items-center justify-between">
      <h2 class="font-semibold flex items-center gap-2">
        <span class="inline-block w-2 h-2 rounded-full bg-emerald-500"></span>
        Live activity
      </h2>
      <span class="text-xs text-slate-400">refresh page to update</span>
    </div>
    <div class="divide-y divide-slate-100">
      <% if (!liveActivity || liveActivity.length === 0) { %>
        <div class="p-6 text-center text-slate-500 text-sm">No tenants have pinged yet.</div>
      <% } else { %>
        <% liveActivity.forEach(function(t) {
          var s = parseInt(t.seconds_ago, 10);
          var ago = s < 60 ? s + 's' : s < 3600 ? Math.floor(s/60) + 'm' : s < 86400 ? Math.floor(s/3600) + 'h' : Math.floor(s/86400) + 'd';
          var isOnline = s < 300;
        %>
          <a href="/customers/<%= t.id %>" class="block px-5 py-3 flex items-center justify-between hover:bg-slate-50">
            <div class="flex items-center gap-2">
              <span class="inline-block w-2 h-2 rounded-full <%= isOnline ? 'bg-emerald-500 animate-pulse' : 'bg-slate-300' %>"></span>
              <div>
                <div class="font-medium text-sm"><%= t.name %></div>
                <div class="text-xs text-slate-500"><%= t.subdomain %></div>
              </div>
            </div>
            <div class="text-xs text-slate-500"><%= isOnline ? 'online' : ago + ' ago' %></div>
          </a>
        <% }) %>
      <% } %>
    </div>
  </div>

  <div class="bg-white border border-slate-200 rounded-xl">
    <div class="px-5 py-3 border-b border-slate-200 flex items-center justify-between">
      <h2 class="font-semibold">Recent customers</h2>
      <a href="/customers" class="text-sm text-slate-600 hover:text-slate-900">View all →</a>
    </div>
    <div class="divide-y divide-slate-100">
      <% if (recent.length === 0) { %>
        <div class="p-6 text-center text-slate-500 text-sm">No customers yet. <a href="/customers/new" class="text-slate-900 underline">Add one</a>.</div>
      <% } else { %>
        <% recent.forEach(function(r) { %>
          <a href="/customers/<%= r.id %>" class="block px-5 py-3 flex items-center justify-between hover:bg-slate-50">
            <div>
              <div class="font-medium"><%= r.name %></div>
              <div class="text-xs text-slate-500"><%= r.subdomain %>.fratelanza.com</div>
            </div>
            <span class="text-xs px-2 py-1 rounded-full <%= r.status === 'active' ? 'bg-emerald-100 text-emerald-700' : 'bg-red-100 text-red-700' %>"><%= r.status %></span>
          </a>
        <% }) %>
      <% } %>
    </div>
  </div>
</div>
<%- include('_footer') %>
