# ============================================================
# Fratelanza VPS — one .env for the whole stack.
# Copy to `.env` on the VPS and replace every CHANGE_ME value.
#
# IMPORTANT: passwords below are used inside Postgres connection URLs.
# Use ONLY letters, digits, underscore (_) and dash (-).
# DO NOT use these characters: @ : / # % ? & space
# (they have special meaning in URLs and will break the connection).
# A good way to generate a safe value: `openssl rand -hex 24`
# ============================================================

# --- CRM database (and where customer tenant DBs live) ---
POSTGRES_PASSWORD=CHANGE_ME_strong_random_alnum

# --- CRM session signing key (any random string, NOT in a URL) ---
SESSION_SECRET=CHANGE_ME_long_random_string

# --- Admin control plane: its OWN metadata DB ---
ADMIN_DB_PASSWORD=CHANGE_ME_different_random_alnum
ADMIN_SESSION_SECRET=CHANGE_ME_another_long_random_string

# --- Admin login (https://admin.fratelanza.com) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_admin_login_password

# --- Shared secret the CRM uses to call the admin's tenant API ---
ADMIN_API_KEY=CHANGE_ME_long_random_string

# --- Password seeded for the `admin` user inside each new tenant DB ---
TENANT_DEFAULT_ADMIN_PASSWORD=CHANGE_ME_tenant_default_password
