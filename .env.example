DATABASE_URL=postgresql://fratelanza:changeme@db:5432/fratelanza
POSTGRES_PASSWORD=changeme
NODE_ENV=production
PORT=3000
STATIC_DIR=/app/artifacts/fratelanza-hub/dist/public
SESSION_SECRET=replace_with_a_long_random_string

# --- Multi-tenancy (Phase 2/3). Leave blank for single-tenant mode. ---
# URL where the Fratelanza-Admin app is reachable from this container.
# On the VPS with admin running via its own compose on host port 2025:
ADMIN_API_URL=http://host.docker.internal:2025
# Must match ADMIN_API_KEY in the admin compose file.
ADMIN_API_KEY=replace_with_the_same_key_set_on_admin_app
# Connection template for per-customer DBs ({db} is replaced at runtime).
# Defaults to the same Postgres + credentials as DATABASE_URL above.
TENANT_DB_URL_TEMPLATE=postgresql://fratelanza:changeme@db:5432/{db}
